# Get these from https://my.telegram.org/apps
# IMPORTANT: keep secrets in .env (do not share them)
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH

PHONE_NUMBER=+1234567890

# Use different values for local vs host (see README)
SESSION_NAME=madapes_local

# Comma-separated: groups and/or channels to monitor
SOURCE_GROUPS=group1,group2

# Comma-separated user IDs allowed to forward from (groups only; channels ignore this)
# Run get_user_ids.py to find IDs
ALLOWED_USER_IDS=123456789,987654321

# MC < threshold → UNDER_80K; MC ≥ threshold → 80K_OR_MORE
DESTINATION_UNDER_80K=channel_small_cap
DESTINATION_80K_OR_MORE=channel_large_cap
MC_THRESHOLD=90000

MAX_SIGNALS=100

# Required for 1h/6h updates and daily report. Channel username (no @), numeric ID, or "me"
REPORT_DESTINATION=my_reports_channel

FORWARD_DELAY=0
DISPLAY_TIMEZONE=America/New_York

# Redis (optional - enables caching, pub/sub events, rate limiting)
# If not set, the bot works without Redis using local fallbacks
REDIS_URL=redis://localhost:6379/0

# Runner detection (near-real-time momentum alerts to report group)
RUNNER_VELOCITY_MIN=1.5
RUNNER_VOL_ACCEL_MIN=1.5
RUNNER_POLL_INTERVAL=90

# API (dashboard backend)
API_KEY=your_api_key_here

# Twitter/X ingestion (optional)
TWITTER_BEARER_TOKEN=
TWITTER_ACCOUNTS=account1,account2
TWITTER_POLL_INTERVAL=120

# Discord ingestion (optional)
DISCORD_BOT_TOKEN=
DISCORD_CHANNELS=channel1,channel2
